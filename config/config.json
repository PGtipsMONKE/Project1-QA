{
  "required_parts": 3,
  "filename_separator": "_",
  "date_format": "%d-%b-%Y",
  "allowed_extensions": [
    "txt",
    "csv",
    "md"
  ],
  "archive_before_date": null,
  "duplicate_policy": "quarantine",
  "ignore_files": [
    ".gitkeep"
  ],
  "classification_prefixes": {
    "invoice": "invoice",
    "report": "report",
    "notes": "notes"
  }
}
